# =============================================================================
# BUR⓪ Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in your actual values

# -----------------------------------------------------------------------------
# Google AI (Gemini) - REQUIRED
# -----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
# Free tier: 250 requests/day, 10 requests/minute
GOOGLE_GENERATIVE_AI_API_KEY="your_gemini_api_key_here"

# -----------------------------------------------------------------------------
# Google Analytics 4 - OPTIONAL
# -----------------------------------------------------------------------------
# Get your Measurement ID from: https://analytics.google.com
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# -----------------------------------------------------------------------------
# NOTE: Authentication, Database, and Payments have been removed
# This app is now completely free and does not require user accounts
# -----------------------------------------------------------------------------
